# .env.example — copy this to .env for local development
# NEVER commit .env to Git — it contains real secrets.
# Render reads environment variables from its dashboard, NOT from this file.

# MongoDB Atlas connection string (SRV format)
# Get this from Atlas → Clusters → Connect → Drivers → Python
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Database name (usually flood_monitor from your FYP)
MONGO_DB=flood_monitor

# How often the SSE endpoint polls MongoDB for new events (seconds)
POLL_INTERVAL_SECONDS=5

# Max events buffered per SSE stream connection
MAX_FEED_EVENTS=50
